# DO NOT EDIT. passenger_wsgi config rules
PassengerAppRoot "/home1/headwayc/poe_backend"
PassengerBaseURI "/api"
PassengerPython "/home1/headwayc/virtualenv/poe_backend/3.10/bin/python"
# END passenger_wsgi config rules

Options +FollowSymLinks

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Skip rewriting for API calls
  RewriteCond %{REQUEST_URI} ^/api/ [NC]
  RewriteRule ^api/(.*)$ - [L]

  # For any other route, if the file or directory does not exist, serve index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
