# DO NOT EDIT. passenger_wsgi config rules
PassengerAppRoot "/home1/headwayc/poe_backend"
PassengerBaseURI "/api"
PassengerPython "/home1/headwayc/virtualenv/poe_backend/3.10/bin/python"
# END passenger_wsgi config rules

Options +FollowSymLinks

# Serve index.html when accessing the root directory
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Specifically serve index.html for the root path
  RewriteRule ^$ /index.html [L]

  # For any other route, if it's not an API call and the file/dir doesn't exist, serve index.html
  RewriteCond %{REQUEST_URI} !^/api/ [NC]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
